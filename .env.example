# Required Telegram bot credentials for /send endpoint
TELEGRAM_TOKEN=your_telegram_bot_token_here
TELEGRAM_CHAT_ID=your_telegram_chat_id_here

# Optional server port
PORT=3000

# Optional Redis store for distributed rate limiting (recommended for multi-instance setup)
REDIS_URL=redis://localhost:6379

# Optional trusted origins for CSRF source checks (comma-separated)
ALLOWED_ORIGINS=https://blcsoftsale.kz,https://www.blcsoftsale.kz,http://localhost:3000,https://monkfish-app-hi9r9.ondigitalocean.app

# Optional log level: fatal | error | warn | info | debug | trace
LOG_LEVEL=info
